# AI Backend — Finetune & Deploy
# Copy to .env and fill in values.

# --- Main backend (ent-triage-system) ---
BACKEND_BASE_URL=http://localhost:8000
BACKEND_USERNAME=ai@test.com
BACKEND_PASSWORD=password67

# --- Triage generator provider (pinned to ollama in this pipeline) ---
LLM_PROVIDER=ollama

# Groq: LLM-as-a-judge when Ollama and RF disagree; plus optional output review (same model)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
ENABLE_LLM_JUDGE=true
ENABLE_LLM_OUTPUT_REVIEW=true

# Ollama finetuned triage model (see mistral_local_deploy/ for GGUF + Modelfile)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=triage-mistral

# Together.ai (if using hosted finetuned model)
# TOGETHER_API_KEY=your_together_api_key
# TOGETHER_MODEL=your-org/ent-triage-qwen

# --- Optional ---
# AI_REDIS_URL=redis://localhost:6379/1
